# ---------------------------------------------------------------------------
# Data model
# ---------------------------------------------------------------------------

@dataclass
class ResourceRecord:
    service: str
    resource_type: str
    name: str
    resource_id: str        # full GCP resource path used in API calls
    location: str
    labels_removed: dict    # label keys that will be / were deleted
    labels_kept: dict       # label keys preserved on the resource
    # Maps actual resource key → canonical target key it matched via
    # normalization or fuzzy matching.  Empty for exact matches.
    # e.g. {"costcanter": "costcentre", "cost_centre": "costcentre"}
    key_matches: dict = field(default_factory=dict)
    status: str = "pending"   # pending | removed | dry-run | skipped | failed
    error: str = ""
    timestamp: str = field(
        default_factory=lambda: datetime.now(timezone.utc).isoformat()
    )

    @property
    def label_count(self) -> int:
        return len(self.labels_removed)

    def to_csv_row(self) -> dict:
        return {
            "service": self.service,
            "resource_type": self.resource_type,
            "name": self.name,
            "resource_id": self.resource_id,
            "location": self.location,
            "labels_removed_count": self.label_count,
            "labels_removed": json.dumps(self.labels_removed),
            "labels_kept": json.dumps(self.labels_kept),
            "key_matches": json.dumps(self.key_matches) if self.key_matches else "",
            "status": self.status,
            "error": self.error,
            "timestamp": self.timestamp,
        }


CSV_FIELDS = [
    "service", "resource_type", "name", "resource_id", "location",
    "labels_removed_count", "labels_removed", "labels_kept", "key_matches",
    "status", "error", "timestamp",
]


# ---------------------------------------------------------------------------
# Main class
# ---------------------------------------------------------------------------

class GCPLabelRemover:

    def __init__(self, project_id: str, dry_run: bool, services: list,
                 label_keys: Optional[set] = None,
                 fuzzy_threshold: float = 0.0,
                 regions: Optional[set] = None):
        self.project_id = project_id
        self.dry_run = dry_run
        self.services = services
        # Normalise to lowercase set; None means "remove all labels"
        self.label_keys: Optional[set] = (
            {k.strip().lower() for k in label_keys if k.strip()}
            if label_keys else None
        )
        # 0.0 = disabled; 0.82 catches most single-char typos
        self.fuzzy_threshold: float = fuzzy_threshold
        # None = scan all regions; set = scan only these regions.
        # A zone like "us-central1-a" is matched to its parent region
        # "us-central1" before the filter is applied.
        self.regions: Optional[set] = (
            {r.strip().lower() for r in regions if r.strip()}
            if regions else None
        )
        self.records: list = []
        self._session = None   # lazy AuthorizedSession

    # -----------------------------------------------------------------------
    # Orchestration
    # -----------------------------------------------------------------------

    def run(self) -> list:
        logger.info(
            "Starting scan | project=%s  dry_run=%s  services=%s",
            self.project_id, self.dry_run, self.services,
        )
        self._fetch_all()
        logger.info("Found %d labeled resource(s).", len(self.records))
        if self.records:
            self._remove_all_labels()
        return self.records

    def _fetch_all(self):
        fetchers = {
            "compute":          self._fetch_compute,
            "networking":       self._fetch_networking,
            "gcs":              self._fetch_gcs,
            "bigquery":         self._fetch_bigquery,
            "gke":              self._fetch_gke,
            "pubsub":           self._fetch_pubsub,
            "run":              self._fetch_cloud_run,
            "functions":        self._fetch_functions,
            "sql":              self._fetch_cloud_sql,
            "kms":              self._fetch_kms,
            "secretmanager":    self._fetch_secretmanager,
            "monitoring":       self._fetch_monitoring,
            "dns":              self._fetch_dns,
            "artifactregistry": self._fetch_artifactregistry,
            "vertexai":         self._fetch_vertexai,
            "vertexaisearch":   self._fetch_vertexaisearch,
            "dataplex":         self._fetch_dataplex,
            "notebooks":        self._fetch_notebooks,
            "workstations":     self._fetch_workstations,
            "healthcare":       self._fetch_healthcare,
            "scheduler":        self._fetch_scheduler,
            "datacatalog":      self._fetch_datacatalog,
        }
        for svc in self.services:
            if svc not in fetchers:
                logger.warning("Unknown service '%s' — skipping.", svc)
                continue
            logger.info("Scanning: %s", svc)
            try:
                self._backoff_retry(fetchers[svc], label=svc)
            except Exception as exc:
                logger.error("Error scanning %s: %s", svc, exc)

    def _remove_all_labels(self):
        dispatch = {
            ("compute",          "instance"):            self._remove_compute_instance_labels,
            ("compute",          "disk"):                self._remove_compute_disk_labels,
            ("compute",          "snapshot"):            self._remove_compute_snapshot_labels,
            ("compute",          "image"):               self._remove_compute_image_labels,
            ("networking",       "forwardingrule"):      self._remove_forwarding_rule_labels,
            ("networking",       "globalforwardingrule"):self._remove_global_forwarding_rule_labels,
            ("networking",       "vpngateway"):          self._remove_vpn_gateway_labels,
            ("networking",       "externalvpngateway"):  self._remove_external_vpn_gateway_labels,
            ("gcs",              "bucket"):              self._remove_gcs_labels,
            ("bigquery",         "dataset"):             self._remove_bigquery_dataset_labels,
            ("bigquery",         "table"):               self._remove_bigquery_table_labels,
            ("gke",              "cluster"):             self._remove_gke_cluster_labels,
            ("pubsub",           "topic"):               self._remove_pubsub_topic_labels,
            ("pubsub",           "subscription"):        self._remove_pubsub_subscription_labels,
            ("run",              "service"):             self._remove_cloud_run_labels,
            ("functions",        "function"):            self._remove_function_labels,
            ("sql",              "instance"):            self._remove_sql_instance_labels,
            ("kms",              "cryptokey"):           self._remove_kms_cryptokey_labels,
            ("secretmanager",    "secret"):              self._remove_secret_labels,
            ("monitoring",       "alertpolicy"):         self._remove_alert_policy_labels,
            ("dns",              "zone"):                self._remove_dns_zone_labels,
            ("artifactregistry", "repository"):          self._remove_artifact_repo_labels,
            ("vertexai",         "dataset"):             self._remove_vertexai_dataset_labels,
            ("vertexai",         "model"):               self._remove_vertexai_model_labels,
            ("vertexai",         "endpoint"):            self._remove_vertexai_endpoint_labels,
            ("vertexaisearch",   "datastore"):           self._remove_vertexaisearch_datastore_labels,
            ("dataplex",         "lake"):                self._remove_dataplex_lake_labels,
            ("dataplex",         "zone"):                self._remove_dataplex_zone_labels,
            ("dataplex",         "asset"):               self._remove_dataplex_asset_labels,
            ("notebooks",        "instance"):            self._remove_notebook_instance_labels,
            ("workstations",     "cluster"):             self._remove_workstation_cluster_labels,
            ("workstations",     "config"):              self._remove_workstation_config_labels,
            ("workstations",     "workstation"):         self._remove_workstation_labels,
            ("healthcare",       "dataset"):             self._remove_healthcare_dataset_labels,
            ("healthcare",       "dicomstore"):          self._remove_healthcare_dicom_store_labels,
            ("healthcare",       "fhirstore"):           self._remove_healthcare_fhir_store_labels,
            ("healthcare",       "hl7v2store"):          self._remove_healthcare_hl7v2_store_labels,
            ("scheduler",        "job"):                 self._remove_scheduler_job_labels,
            ("datacatalog",      "entrygroup"):          self._remove_datacatalog_entrygroup_labels,
        }

        for rec in self.records:
            if self.dry_run:
                rec.status = "dry-run"
                logger.info(
                    "[DRY-RUN] Would remove %d label(s) %s from %s/%s: %s"
                    " (keeping: %s)",
                    rec.label_count, list(rec.labels_removed.keys()),
                    rec.service, rec.resource_type, rec.name,
                    list(rec.labels_kept.keys()) or "nothing",
                )
                continue
            remover = dispatch.get((rec.service, rec.resource_type))
            if remover is None:
                rec.status = "skipped"
                continue
            try:
                remover(rec)
                rec.status = "removed"
                logger.info(
                    "Removed %d label(s) from %s/%s: %s",
                    rec.label_count, rec.service, rec.resource_type, rec.name,
                )
            except Exception as exc:
                rec.status = "failed"
                rec.error = str(exc)
                logger.error(
                    "FAILED %s/%s %s: %s",
                    rec.service, rec.resource_type, rec.name, exc,
                )

    # -----------------------------------------------------------------------
    # Shared helpers
    # -----------------------------------------------------------------------

    def _record(self, service, rtype, name, resource_id, location, all_labels):
        # Region filter — applied before anything else.
        # Covers ALL services: wildcard fetches return all regions but only
        # resources whose location matches the filter are recorded.
        if not self._in_regions(location):
            return

        all_labels = dict(all_labels)

        if self.label_keys is not None:
            labels_removed: dict = {}
            key_matches: dict = {}      # actual_key → canonical_target

            for k, v in all_labels.items():
                matched = self._matched_target(k)
                if matched is not None:
                    labels_removed[k] = v
                    # Record non-exact matches so they appear in the CSV
                    if matched != k.lower():
                        key_matches[k] = matched
                        logger.warning(
                            "Key variant matched — resource %s/%s '%s': "
                            "label key '%s' matched target '%s'",
                            rtype, name, resource_id, k, matched,
                        )

            labels_kept = {k: v for k, v in all_labels.items()
                           if k not in labels_removed}
        else:
            labels_removed = all_labels
            labels_kept = {}
            key_matches = {}

        if not labels_removed:
            return  # resource carries none of the target keys — skip it

        self.records.append(ResourceRecord(
            service=service, resource_type=rtype,
            name=name, resource_id=resource_id,
            location=location,
            labels_removed=labels_removed,
            labels_kept=labels_kept,
            key_matches=key_matches,
        ))

    @staticmethod
    def _region_of(location: str) -> str:
        """
        Normalize a zone or region string to its parent region.

        "us-central1-a" → "us-central1"   (zone → region)
        "us-central1"   → "us-central1"   (already a region)
        "global"        → "global"
        """
        loc = location.split("/")[-1]          # strip "zones/" / "regions/" prefix
        parts = loc.rsplit("-", 1)
        # A zone always ends with a single letter (a, b, c, f …)
        if len(parts) == 2 and len(parts[1]) == 1 and parts[1].isalpha():
            return parts[0]
        return loc

    def _in_regions(self, location: str) -> bool:
        """Return True if this resource location is within the region filter."""
        if self.regions is None:
            return True
        if location in ("global", "unknown"):
            return True   # global/unknown resources are never region-filtered
        return self._region_of(location) in self.regions

    def _authed_get(self, url: str) -> dict:
        import google.auth
        import google.auth.transport.requests
        import requests as http_requests

        if self._session is None:
            creds, _ = google.auth.default()
            self._session = google.auth.transport.requests.AuthorizedSession(creds)
        resp = self._session.get(url)
        resp.raise_for_status()
        return resp.json()

    def _list_locations(self, endpoint: str) -> list:
        """
        Return the location IDs to iterate for a given service endpoint.

        Priority:
          1. If --regions was supplied, return those regions immediately
             (no API call needed — saves quota and time).
          2. Otherwise, call the service's locations API.
          3. Fall back to COMMON_REGIONS if the API call fails.
        """
        if self.regions is not None:
            return sorted(self.regions)   # user-specified; no API call at all
        try:
            data = self._authed_get(
                f"https://{endpoint}/v1/projects/{self.project_id}/locations"
            )
            return [loc["locationId"] for loc in data.get("locations", [])]
        except Exception as exc:
            logger.debug(
                "Could not list locations for %s (%s) — using common regions.",
                endpoint, exc,
            )
            return COMMON_REGIONS

    def _matched_target(self, key: str) -> Optional[str]:
        """
        Return the canonical target key that *key* matches, or None.

        Matching layers (applied in order):
          1. Exact        — case-insensitive string equality
          2. Normalized   — strip hyphens, underscores, spaces then compare
          3. Fuzzy        — difflib ratio >= self.fuzzy_threshold (if > 0)

        Only called when self.label_keys is not None.
        """
        key_lower = key.lower()

        # Layer 1: exact (case-insensitive)
        if key_lower in self.label_keys:
            return key_lower

        key_norm = re.sub(r"[-_\s]", "", key_lower)

        best_target: Optional[str] = None
        best_score: float = 0.0

        for target in self.label_keys:
            # Layer 2: normalized equality
            if key_norm == re.sub(r"[-_\s]", "", target):
                return target

            # Layer 3: fuzzy — track best score across all targets
            if self.fuzzy_threshold > 0.0:
                score = difflib.SequenceMatcher(None, key_lower, target).ratio()
                if score > best_score:
                    best_score = score
                    best_target = target

        if self.fuzzy_threshold > 0.0 and best_score >= self.fuzzy_threshold:
            return best_target

        return None

    # -----------------------------------------------------------------------
    # Reliability helpers
    # -----------------------------------------------------------------------

    @staticmethod
    def _paginate_rest(list_callable: Callable, items_key: str, **kwargs) -> list:
        """
        Iterate ALL pages of a googleapiclient.discovery list call.

        list_callable — bound list method, e.g. sqladmin.instances().list
        items_key     — the key that holds the list in the response dict

        googleapiclient only returns one page per execute(); callers that
        omit this loop silently drop every resource beyond the first page.
        """
        items: list = []
        page_token: Optional[str] = None
        while True:
            if page_token:
                kwargs["pageToken"] = page_token
            response = list_callable(**kwargs).execute()
            items.extend(response.get(items_key) or [])
            page_token = response.get("nextPageToken")
            if not page_token:
                break
        return items

    def _fingerprint_retry(self, fn: Callable, max_retries: int = 3):
        """
        Run fn(), retrying on fingerprint conflict errors.

        Two different HTTP status codes are used across GCP services:
          - Compute Engine set_labels → 412 Precondition Failed
            → google.api_core.exceptions.FailedPrecondition
          - GKE SetLabels            → 409 Conflict / Aborted
            → google.api_core.exceptions.Aborted

        Both are retried here.  fn() must re-fetch the resource (and its
        fresh fingerprint) on each attempt — never cache the fingerprint
        outside fn().
        """
        from google.api_core import exceptions as api_exc
        _conflict = (api_exc.FailedPrecondition, api_exc.Aborted)
        for attempt in range(max_retries):
            try:
                return fn()
            except _conflict as exc:
                if attempt == max_retries - 1:
                    raise
                wait = 2 ** attempt   # 1s, 2s, 4s …
                logger.warning(
                    "Fingerprint conflict (%s) — retry %d/%d in %ds",
                    type(exc).__name__, attempt + 1, max_retries, wait,
                )
                time.sleep(wait)

    def _backoff_retry(self, fn: Callable, label: str = "", max_retries: int = 5):
        """
        Run fn(), retrying on quota (429 ResourceExhausted) and transient
        (503 ServiceUnavailable) errors with exponential backoff.

        ResourceExhausted errors were previously in _skip_exc() which caused
        them to be silently dropped. They are now retried instead.
        """
        from google.api_core import exceptions as api_exc
        for attempt in range(max_retries):
            try:
                return fn()
            except (api_exc.ResourceExhausted, api_exc.ServiceUnavailable) as exc:
                if attempt == max_retries - 1:
                    raise
                wait = min(60, 2 ** attempt)
                logger.warning(
                    "Transient error%s (attempt %d/%d) — retrying in %ds: %s",
                    f" [{label}]" if label else "", attempt + 1, max_retries, wait, exc,
                )
                time.sleep(wait)

    def _new_labels(self, current: dict) -> dict:
        """
        Return the labels that should remain on a resource after removal.

        If label_keys is set → drop keys that match any target (exact /
        normalised / fuzzy).  Everything else is preserved.
        If label_keys is None → drop all (original behaviour).
        """
        if self.label_keys is None:
            return {}
        return {k: v for k, v in current.items()
                if self._matched_target(k) is None}

    @staticmethod
    def _skip_exc():
        """
        Exceptions that indicate a service/resource is simply not in use for
        this project and should be silently skipped.

        ResourceExhausted (quota) is NOT listed here — it is retried with
        backoff via _backoff_retry() instead of being silently ignored.
        """
        from google.api_core import exceptions as api_exc
        return (
            api_exc.NotFound,
            api_exc.PermissionDenied,
            api_exc.InvalidArgument,
        )

    # -----------------------------------------------------------------------
    # Compute Engine
    # -----------------------------------------------------------------------

    def _fetch_compute(self):
        from google.cloud import compute_v1

        for zone, scoped in compute_v1.InstancesClient().aggregated_list(project=self.project_id):
            for r in getattr(scoped, "instances", []):
                if r.labels:
                    self._record("compute", "instance", r.name, r.self_link,
                                 zone.split("/")[-1], r.labels)

        for zone, scoped in compute_v1.DisksClient().aggregated_list(project=self.project_id):
            for r in getattr(scoped, "disks", []):
                if r.labels:
                    self._record("compute", "disk", r.name, r.self_link,
                                 zone.split("/")[-1], r.labels)

        for r in compute_v1.SnapshotsClient().list(project=self.project_id):
            if r.labels:
                self._record("compute", "snapshot", r.name, r.self_link, "global", r.labels)

        for r in compute_v1.ImagesClient().list(project=self.project_id):
            if r.labels:
                self._record("compute", "image", r.name, r.self_link, "global", r.labels)

    def _remove_compute_instance_labels(self, rec: ResourceRecord):
        from google.cloud import compute_v1
        c = compute_v1.InstancesClient()
        def _do():
            inst = c.get(project=self.project_id, zone=rec.location, instance=rec.name)
            c.set_labels(
                project=self.project_id, zone=rec.location, instance=rec.name,
                instances_set_labels_request_resource=compute_v1.InstancesSetLabelsRequest(
                    label_fingerprint=inst.label_fingerprint,
                    labels=self._new_labels(dict(inst.labels)),
                ),
            ).result()
        self._fingerprint_retry(_do)

    def _remove_compute_disk_labels(self, rec: ResourceRecord):
        from google.cloud import compute_v1
        c = compute_v1.DisksClient()
        def _do():
            disk = c.get(project=self.project_id, zone=rec.location, disk=rec.name)
            c.set_labels(
                project=self.project_id, zone=rec.location, disk=rec.name,
                zone_set_labels_request_resource=compute_v1.ZoneSetLabelsRequest(
                    label_fingerprint=disk.label_fingerprint,
                    labels=self._new_labels(dict(disk.labels)),
                ),
            ).result()
        self._fingerprint_retry(_do)

    def _remove_compute_snapshot_labels(self, rec: ResourceRecord):
        from google.cloud import compute_v1
        c = compute_v1.SnapshotsClient()
        def _do():
            snap = c.get(project=self.project_id, snapshot=rec.name)
            c.set_labels(
                project=self.project_id, resource=rec.name,
                global_set_labels_request_resource=compute_v1.GlobalSetLabelsRequest(
                    label_fingerprint=snap.label_fingerprint,
                    labels=self._new_labels(dict(snap.labels)),
                ),
            ).result()
        self._fingerprint_retry(_do)

    def _remove_compute_image_labels(self, rec: ResourceRecord):
        from google.cloud import compute_v1
