ALL_SERVICES = [
    "compute", "networking", "gcs", "bigquery", "gke", "pubsub",
    "run", "functions", "sql", "kms", "secretmanager", "monitoring",
    "dns", "artifactregistry", "vertexai", "vertexaisearch",
    "dataplex", "notebooks", "workstations", "healthcare",
    "scheduler", "datacatalog",
]


@click.command()
@click.option("--project", required=True, help="GCP project ID")
@click.option(
    "--dry-run/--execute", default=True, show_default=True,
    help="--dry-run (default) previews; --execute removes labels.",
)
@click.option(
    "--services", default=",".join(ALL_SERVICES), show_default=False,
    help="Comma-separated services to scan. Default: all supported services.",
)
@click.option(
    "--label-keys", default=None,
    help=(
        "Comma-separated label KEY names to target (e.g. costcentre,apmid). "
        "Only labels whose key matches are removed; all other labels are preserved. "
        "Omit to remove ALL labels."
    ),
)
@click.option(
    "--regions", default=None,
    help=(
        "Comma-separated GCP regions to scan (e.g. us-central1,us-east1). "
        "Zones are mapped to their parent region automatically "
        "(us-central1-a → us-central1). "
        "Global and unknown-location resources are always included. "
        "Omit to scan all regions."
    ),
)
@click.option(
    "--fuzzy-threshold", default=0.0, type=float, show_default=True,
    help=(
        "Similarity ratio (0.0–1.0) for fuzzy key matching. "
        "0.0 disables fuzzy matching (default). "
        "0.82 catches most single-character typos "
        "(e.g. costcanter ≈ costcentre, costcenter ≈ costcentre). "
        "Normalization of separators (- _ space) is always applied regardless "
        "of this setting."
    ),
)
@click.option(
    "--output", default=None,
    help="CSV output path. Default: gcp_label_audit_<timestamp>.csv",
)
def main(project: str, dry_run: bool, services: str,
         label_keys: Optional[str], regions: Optional[str],
         fuzzy_threshold: float, output: Optional[str]):
    """Remove specific (or all) labels from GCP resources and produce an audit CSV."""
    service_list = [s.strip().lower() for s in services.split(",") if s.strip()]
    key_set = (
        {k.strip().lower() for k in label_keys.split(",") if k.strip()}
        if label_keys else None
    )
    region_set = (
        {r.strip().lower() for r in regions.split(",") if r.strip()}
        if regions else None
    )

    if dry_run:
        logger.info("=== DRY-RUN MODE — no changes will be made ===")
    else:
        logger.warning("=== EXECUTE MODE — labels will be permanently removed ===")
        click.confirm("Proceed with label removal?", abort=True)

    if region_set:
        logger.info("Region filter: %s", sorted(region_set))
    else:
        logger.info("No --regions filter — scanning all regions.")

    if key_set:
        logger.info("Targeting label keys: %s", sorted(key_set))
        if fuzzy_threshold > 0.0:
            logger.info("Fuzzy matching enabled — threshold: %.2f", fuzzy_threshold)
        else:
            logger.info("Fuzzy matching disabled (separator normalisation always on)")
    else:
        logger.info("No --label-keys filter — ALL labels will be removed.")

    records = GCPLabelRemover(
        project_id=project,
        dry_run=dry_run,
        services=service_list,
        label_keys=key_set,
        fuzzy_threshold=fuzzy_threshold,
        regions=region_set,
    ).run()

    if not records:
        logger.info("No labeled resources found. No CSV generated.")
        sys.exit(0)

    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    csv_path = output or f"gcp_label_audit_{ts}.csv"
    write_csv(records, csv_path)


if __name__ == "__main__":
    main()
