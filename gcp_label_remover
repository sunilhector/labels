            )
        ).result()

    # -----------------------------------------------------------------------
    # Cloud Workstations — Clusters, Configs, Workstations
    # -----------------------------------------------------------------------

    def _fetch_workstations(self):
        from google.cloud import workstations_v1
        client = workstations_v1.WorkstationsClient()
        try:
            for cluster in client.list_workstation_clusters(
                    parent=f"projects/{self.project_id}/locations/-"):
                loc = cluster.name.split("/")[3]
                if cluster.labels:
                    self._record("workstations", "cluster",
                                 cluster.name.split("/")[-1], cluster.name,
                                 loc, cluster.labels)
                for config in client.list_workstation_configs(parent=cluster.name):
                    if config.labels:
                        self._record("workstations", "config",
                                     config.name.split("/")[-1], config.name,
                                     loc, config.labels)
                    for ws in client.list_workstations(parent=config.name):
                        if ws.labels:
                            self._record("workstations", "workstation",
                                         ws.name.split("/")[-1], ws.name,
                                         loc, ws.labels)
        except self._skip_exc():
            pass

    def _remove_workstation_cluster_labels(self, rec: ResourceRecord):
