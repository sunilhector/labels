    def _fetch_vertexai(self):
        from google.cloud import aiplatform_v1

        # Prefer dynamic discovery; fall back to the curated list if the
        # locations endpoint is unreachable (e.g. API not enabled).
        locations = self._list_locations("aiplatform.googleapis.com")
        if locations == COMMON_REGIONS:
            locations = VERTEX_AI_REGIONS
        locations = [loc for loc in locations if loc != "global"]

        for loc in locations:
            opts = {"api_endpoint": f"{loc}-aiplatform.googleapis.com"}
            parent = f"projects/{self.project_id}/locations/{loc}"

            for ClientCls, rtype in [
                (aiplatform_v1.DatasetServiceClient,  "dataset"),
                (aiplatform_v1.ModelServiceClient,    "model"),
                (aiplatform_v1.EndpointServiceClient, "endpoint"),
            ]:
                try:
                    client = ClientCls(client_options=opts)
                    list_fn = {
                        "dataset":  client.list_datasets,
                        "model":    client.list_models,
                        "endpoint": client.list_endpoints,
                    }[rtype]
                    for resource in list_fn(parent=parent):
                        if resource.labels:
                            self._record("vertexai", rtype,
                                         resource.name.split("/")[-1], resource.name,
                                         loc, resource.labels)
                except self._skip_exc():
                    pass
                except Exception as exc:
                    logger.debug("Vertex AI %s skip %s: %s", rtype, loc, exc)

