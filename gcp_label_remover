    # -----------------------------------------------------------------------
    # Notebooks (Vertex AI Workbench)
    # -----------------------------------------------------------------------

    def _fetch_notebooks(self):
        from google.cloud import notebooks_v2
        try:
            for inst in notebooks_v2.NotebookServiceClient().list_instances(
                    parent=f"projects/{self.project_id}/locations/-"):
                if inst.labels:
                    self._record("notebooks", "instance",
                                 inst.name.split("/")[-1], inst.name,
                                 inst.name.split("/")[3], inst.labels)
        except self._skip_exc():
            pass

    def _remove_notebook_instance_labels(self, rec: ResourceRecord):
        from google.cloud import notebooks_v2
        from google.protobuf import field_mask_pb2
        client = notebooks_v2.NotebookServiceClient()
