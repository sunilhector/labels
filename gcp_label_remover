    # -----------------------------------------------------------------------
    # Cloud Healthcare — Datasets, DICOM / FHIR / HL7v2 Stores
    # -----------------------------------------------------------------------

    def _fetch_healthcare(self):
        import googleapiclient.discovery
        hc = googleapiclient.discovery.build("healthcare", "v1")
        locations = self._list_locations("healthcare.googleapis.com")
        for loc in locations:
            if loc == "global":
                continue
            parent = f"projects/{self.project_id}/locations/{loc}"
            try:
                # datasets.list is paginated — must follow nextPageToken.
                datasets = self._paginate_rest(
                    hc.projects().locations().datasets().list,
                    "datasets", parent=parent,
                )
            except Exception as exc:
                logger.debug("Healthcare skip location %s: %s", loc, exc)
                continue

            for dataset in datasets:
                ds_name = dataset["name"]
                ds_id = ds_name.split("/")[-1]
                if dataset.get("labels"):
                    self._record("healthcare", "dataset", ds_id, ds_name, loc,
                                 dataset["labels"])

                store_configs = [
                    ("dicomStores", "dicomstore",
                     hc.projects().locations().datasets().dicomStores()),
                    ("fhirStores",  "fhirstore",
                     hc.projects().locations().datasets().fhirStores()),
                    ("hl7V2Stores", "hl7v2store",
                     hc.projects().locations().datasets().hl7V2Stores()),
                ]
                for list_key, rtype, resource_api in store_configs:
                    try:
                        # Each store list is also paginated.
                        stores = self._paginate_rest(
                            resource_api.list, list_key, parent=ds_name
                        )
                        for store in stores:
                            if store.get("labels"):
                                self._record("healthcare", rtype,
                                             store["name"].split("/")[-1], store["name"],
                                             loc, store["labels"])
                    except Exception as exc:
                        logger.debug("Healthcare %s skip %s: %s", rtype, ds_name, exc)

    def _remove_healthcare_dataset_labels(self, rec: ResourceRecord):
        import googleapiclient.discovery
        hc = googleapiclient.discovery.build("healthcare", "v1")
        current = hc.projects().locations().datasets().get(name=rec.resource_id).execute()
        hc.projects().locations().datasets().patch(
            name=rec.resource_id, updateMask="labels",
            body={"labels": self._new_labels(current.get("labels", {}))},
        ).execute()

    def _remove_healthcare_dicom_store_labels(self, rec: ResourceRecord):
        import googleapiclient.discovery
        hc = googleapiclient.discovery.build("healthcare", "v1")
        api = hc.projects().locations().datasets().dicomStores()
        current = api.get(name=rec.resource_id).execute()
        api.patch(
            name=rec.resource_id, updateMask="labels",
