    # -----------------------------------------------------------------------
    # Cloud Scheduler
    # -----------------------------------------------------------------------

    def _fetch_scheduler(self):
        from google.cloud import scheduler_v1
        client = scheduler_v1.CloudSchedulerClient()
        locations = self._list_locations("cloudscheduler.googleapis.com")
        for loc in locations:
            if loc == "global":
                continue
            try:
                for job in client.list_jobs(
                        request={"parent": f"projects/{self.project_id}/locations/{loc}"}):
                    if job.labels:
                        self._record("scheduler", "job",
                                     job.name.split("/")[-1], job.name,
                                     loc, job.labels)
            except self._skip_exc():
                pass
            except Exception as exc:
                logger.debug("Scheduler skip %s: %s", loc, exc)

    def _remove_scheduler_job_labels(self, rec: ResourceRecord):
        from google.cloud import scheduler_v1
        from google.protobuf import field_mask_pb2
        client = scheduler_v1.CloudSchedulerClient()
        current = client.get_job(name=rec.resource_id)
        client.update_job(
            request=scheduler_v1.UpdateJobRequest(
                job=scheduler_v1.Job(
                    name=rec.resource_id,
                    labels=self._new_labels(dict(current.labels)),
                ),
                update_mask=field_mask_pb2.FieldMask(paths=["labels"]),
            )
        )

    # -----------------------------------------------------------------------
    # Data Catalog — Entry Groups
    # -----------------------------------------------------------------------

    def _fetch_datacatalog(self):
        from google.cloud import datacatalog_v1
        # Data Catalog does NOT support the locations/- wildcard.
        # Iterate each location explicitly.
        client = datacatalog_v1.DataCatalogClient()
        locations = self._list_locations("datacatalog.googleapis.com")
        for loc in locations:
            parent = f"projects/{self.project_id}/locations/{loc}"
            try:
                for eg in client.list_entry_groups(parent=parent):
                    labels = dict(getattr(eg, "labels", {}) or {})
                    if labels:
                        self._record("datacatalog", "entrygroup",
                                     eg.name.split("/")[-1], eg.name, loc, labels)
            except self._skip_exc():
                pass
            except Exception as exc:
                logger.debug("Data Catalog skip %s: %s", loc, exc)

    def _remove_datacatalog_entrygroup_labels(self, rec: ResourceRecord):
        from google.cloud import datacatalog_v1
        from google.protobuf import field_mask_pb2
        client = datacatalog_v1.DataCatalogClient()
        current = client.get_entry_group(name=rec.resource_id)
        current_labels = dict(getattr(current, "labels", {}) or {})
        client.update_entry_group(
            request=datacatalog_v1.UpdateEntryGroupRequest(
                entry_group=datacatalog_v1.EntryGroup(
                    name=rec.resource_id,
                    labels=self._new_labels(current_labels),
                ),
                update_mask=field_mask_pb2.FieldMask(paths=["labels"]),
            )
        )


# ---------------------------------------------------------------------------
# CSV report + summary
# ---------------------------------------------------------------------------

def write_csv(records: list, output_path: str):
    with open(output_path, "w", newline="", encoding="utf-8") as f:
        writer = csv.DictWriter(f, fieldnames=CSV_FIELDS)
        writer.writeheader()
        writer.writerows(r.to_csv_row() for r in records)

    total = len(records)
    total_labels = sum(r.label_count for r in records)
    by_status: dict = {}
    by_service: dict = {}
    for r in records:
        by_status[r.status] = by_status.get(r.status, 0) + 1
        by_service[r.service] = by_service.get(r.service, 0) + 1

    logger.info("─" * 50)
    logger.info("Audit summary")
    logger.info("  Total resources : %d", total)
    logger.info("  Total labels    : %d", total_labels)
    logger.info("  By status:")
    for status, count in sorted(by_status.items()):
        logger.info("    %-12s : %d", status, count)
    logger.info("  By service:")
    for svc, count in sorted(by_service.items()):
        logger.info("    %-20s : %d", svc, count)
    logger.info("  Report → %s", output_path)
    logger.info("─" * 50)


