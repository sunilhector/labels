    def _remove_sql_instance_labels(self, rec: ResourceRecord):
        import googleapiclient.discovery
        sqladmin = googleapiclient.discovery.build("sqladmin", "v1")
        # GET current labels live
        current = sqladmin.instances().get(
            project=self.project_id, instance=rec.name
        ).execute()
        current_labels = current.get("userLabels", {})
        # Set targeted keys to None (SQL API deletes them), keep the rest
        patch_labels = {k: None for k in rec.labels_removed if k in current_labels}
        patch_labels.update(self._new_labels(current_labels))
        sqladmin.instances().patch(
            project=self.project_id, instance=rec.name,
            body={"userLabels": patch_labels},
        ).execute()

